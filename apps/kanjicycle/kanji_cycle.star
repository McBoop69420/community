FRAME_DELAY_MS = 1200
FONT_NAME = "6x13"  # fallback if an image is missing
FG_COLOR = "#F8F9FA"
BG_COLOR = "#080808"
GLYPH_WIDTH = 40
GLYPH_HEIGHT = 32
LABEL_FONT = "6x13"

ROMAJI_MAP = {
    "あ": "a",
    "い": "i",
    "う": "u",
    "え": "e",
    "お": "o",
    "か": "ka",
    "き": "ki",
