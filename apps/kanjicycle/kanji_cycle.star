    "る": "ru",
    "れ": "re",
    "ろ": "ro",
    "わ": "wa",
    "を": "o",
    "ん": "n",
}

ROMAJI_TO_HIRAGANA = {v: k for k, v in ROMAJI_MAP.items()}

CONFIG_SCHEMA = schema.Schema(
    version = "1",
    fields = [
        schema.Text(
            id = "characters",
            name = "Characters",
            desc = "Enter the characters to cycle through. Leave blank to use the full Hiragana set.",
            icon = "signature",
        ),
    ],
)

def main(config):
    characters = selectedcharacters(config)
    frames = [_make_frame(ch) for ch in characters]

    return render.Root(
        delay = FRAME_DELAY_MS,
        child = render.Box(
            width = 64,
            height = 32,
            child = render.Animation(children = frames),
        ),
    )

def get_schema():
    return CONFIG_SCHEMA

def selectedcharacters(config):
    config_characters = charactersfrom_text(config.get("characters"))
    if config_characters:
        return config_characters

    return DEFAULT_CHARACTERS

def _make_frame(character):
    glyph_encoded = HIRAGANA_IMAGES.get(character)
    glyph = (
        render.Image(
            src = base64.decode(glyph_encoded),
            width = GLYPH_WIDTH,
            height = GLYPH_HEIGHT,
        ) if glyph_encoded else render.Text(
            content = character,
            font = FONT_NAME,
            color = FG_COLOR,
        )
    )

    glyph_box = render.Box(
        width = GLYPH_WIDTH,
        height = 32,
        child = glyph,
    )

    return render.Stack(
        children = [
            render.Box(
                width = 64,
                height = 32,
                color = BG_COLOR,
            ),
            render.Row(
                expanded = True,
                main_align = "center",
                cross_align = "center",
                children = [
                    glyph_box,
                    render.Padding(
                        pad = (2, 0, 0, 0),
                        child = labelwidget(character),
                    ),
                ],
            ),
        ],
    )

def labelwidget(character):
    label = ROMAJI_MAP.get(character, "?")
    return render.Text(
        content = label.upper(),
        font = LABEL_FONT,
        color = FG_COLOR,
    )

def charactersfrom_text(text):
    if not text:
        return []

    lines = []
    for line in text.splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        lines.append(stripped)

    cleaned = " ".join(lines).replace(",", " ").lower()
    tokens = [token for token in cleaned.split() if token]
    if not tokens:
        return []

    result = []
    for token in tokens:
        # Prefer exact Hiragana entry. Otherwise, treat as romaji if mapped.
        if token in HIRAGANA_IMAGES:
            result.append(token)
        elif token in ROMAJI_TO_HIRAGANA:
            result.append(ROMAJI_TO_HIRAGANA[token])
    return result

